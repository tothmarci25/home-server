# List of USB disks to be mounted
usb_disks:
  - name: ssd
    uuid: "<UUID of your storage device>"
    size: 2000Gi
    storageClass: local-ssd
  - name: red
    uuid: "<UUID of your storage device>"
    size: 8000Gi
    storageClass: local-red
  - name: wd
    uuid: "<UUID of your storage device>"
    size: 2000Gi
    storageClass: local-wd
    fstype: ntfs

# Mapping apps to volumes
app_storage_map:
  plex:
    extraVolumes:
      - name: plex-config
        persistentVolumeClaim:
          claimName: plex-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
      - name: local-wd
        persistentVolumeClaim:
          claimName: wd-pvc
      - name: local-red
        persistentVolumeClaim:
          claimName: red-pvc
    extraVolumeMounts:
      - name: plex-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data
        subPath: data/media
      - name: local-wd
        mountPath: /data/wd
        subPath: data/wd/media
      - name: local-red
        mountPath: /data/red
        subPath: data/red/media
  radarr:
    extraVolumes:
      - name: radarr-config
        persistentVolumeClaim:
          claimName: radarr-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
      - name: local-wd
        persistentVolumeClaim:
          claimName: wd-pvc
      - name: local-red
        persistentVolumeClaim:
          claimName: red-pvc
    extraVolumeMounts:
      - name: radarr-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data
        subPath: data
      - name: local-wd
        mountPath: /data/wd
        subPath: data/wd
      - name: local-red
        mountPath: /data/red
        subPath: data/red
  sonarr:
    extraVolumes:
      - name: sonarr-config
        persistentVolumeClaim:
          claimName: sonarr-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
      - name: local-wd
        persistentVolumeClaim:
          claimName: wd-pvc
      - name: local-red
        persistentVolumeClaim:
          claimName: red-pvc
    extraVolumeMounts:
      - name: sonarr-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data
        subPath: data
      - name: local-wd
        mountPath: /data/wd
        subPath: data/wd
      - name: local-red
        mountPath: /data/red
        subPath: data/red
  jackett:
    extraVolumes:
      - name: jackett-config
        persistentVolumeClaim:
          claimName: jackett-config
    extraVolumeMounts:
      - name: jackett-config
        mountPath: /config
  qbittorrent:
    extraVolumes:
      - name: qbittorrent-config
        persistentVolumeClaim:
          claimName: qbittorrent-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
      - name: local-wd
        persistentVolumeClaim:
          claimName: wd-pvc
      - name: local-red
        persistentVolumeClaim:
          claimName: red-pvc
    extraVolumeMounts:
      - name: qbittorrent-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data/torrents
        subPath: data/torrents
      - name: local-wd
        mountPath: /data/wd/torrents
        subPath: data/wd/torrents
      - name: local-red
        mountPath: /data/red/torrents
        subPath: data/red/torrents
  filebrowser:
    extraVolumes:
      - name: filebrowser-config
        persistentVolumeClaim:
          claimName: filebrowser-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
      - name: local-wd
        persistentVolumeClaim:
          claimName: wd-pvc
      - name: local-red
        persistentVolumeClaim:
          claimName: red-pvc
    extraVolumeMounts:
      - name: filebrowser-config
        mountPath: /database/filebrowser.db
        subPath: filebrowser.db
      - name: filebrowser-config
        mountPath: /config/settings.json
        subPath: settings.json
      - name: local-ssd
        mountPath: /srv/ssd
      - name: local-wd
        mountPath: /srv/wd
      - name: local-red
        mountPath: /srv/red

# Longhorn PVCs for app config volumes
longhorn_pvcs:
  - name: plex-config
    size: 20Gi
  - name: radarr-config
    size: 5Gi
  - name: sonarr-config
    size: 5Gi
  - name: jackett-config
    size: 2Gi
  - name: qbittorrent-config
    size: 2Gi
  - name: filebrowser-config
    size: 1Gi

# Vault PV configuration
vault_disk_name: "ssd"   # disk from usb_disks used for vault storage paths

# Node and repo info
k8s_node_name: "{{ inventory_hostname }}"
repo_root: "{{ playbook_dir }}/../.."
