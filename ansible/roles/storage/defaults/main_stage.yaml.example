# List of USB disks to be mounted
usb_disks:
  - name: ssd
    uuid: "<UUID of your storage device>"
    size: 16Gi
    storageClass: local-ssd

# Mapping apps to volumes
app_storage_map:
  plex:
    extraVolumes:
      - name: plex-config
        persistentVolumeClaim:
          claimName: plex-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
    extraVolumeMounts:
      - name: plex-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data
        subPath: data/media
  radarr:
    extraVolumes:
      - name: radarr-config
        persistentVolumeClaim:
          claimName: radarr-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
    extraVolumeMounts:
      - name: radarr-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data
        subPath: data
  sonarr:
    extraVolumes:
      - name: sonarr-config
        persistentVolumeClaim:
          claimName: sonarr-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
    extraVolumeMounts:
      - name: sonarr-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data
        subPath: data
  jackett:
    extraVolumes:
      - name: jackett-config
        persistentVolumeClaim:
          claimName: jackett-config
    extraVolumeMounts:
      - name: jackett-config
        mountPath: /config
  qbittorrent:
    extraVolumes:
      - name: qbittorrent-config
        persistentVolumeClaim:
          claimName: qbittorrent-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
    extraVolumeMounts:
      - name: qbittorrent-config
        mountPath: /config
      - name: local-ssd
        mountPath: /data/torrents
        subPath: data/torrents
  filebrowser:
    extraVolumes:
      - name: filebrowser-config
        persistentVolumeClaim:
          claimName: filebrowser-config
      - name: local-ssd
        persistentVolumeClaim:
          claimName: ssd-pvc
    extraVolumeMounts:
      - name: filebrowser-config
        mountPath: /database/filebrowser.db
        subPath: filebrowser.db
      - name: filebrowser-config
        mountPath: /config/settings.json
        subPath: settings.json
      - name: local-ssd
        mountPath: /srv/ssd

# Longhorn PVCs for app config volumes
longhorn_pvcs:
  - name: plex-config
    size: 10Gi
  - name: radarr-config
    size: 5Gi
  - name: sonarr-config
    size: 5Gi
  - name: jackett-config
    size: 2Gi
  - name: qbittorrent-config
    size: 2Gi
  - name: filebrowser-config
    size: 1Gi

# Vault PV configuration
vault_disk_name: "ssd"   # disk from usb_disks used for vault storage paths

# Node and repo info
k8s_node_name: "{{ inventory_hostname }}"
repo_root: "{{ playbook_dir }}/../.."
